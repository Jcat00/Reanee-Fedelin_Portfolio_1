<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reanee Fedelin — Executive Virtual Assistant</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --space: #04060f;
    --deep: #080d1f;
    --nebula: #0d1535;
    --accent: #c9a96e;
    --gold: #e8c87a;
    --rose: #d4a0b0;
    --star: #f0eadc;
    --text: #c8cde0;
    --soft: #8891b0;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--space);
    color: var(--text);
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  #stars { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 60px;
    background: linear-gradient(to bottom, rgba(4,6,15,0.95), transparent);
  }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    font-weight: 300;
    letter-spacing: 0.2em;
    color: var(--accent);
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    gap: 36px;
    list-style: none;
  }

  .nav-links a {
    color: var(--star);
    text-decoration: none;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    transition: color 0.3s;
  }

  .nav-links a:hover { color: var(--gold); }

  section { position: relative; z-index: 1; }

  /* HERO */
  #hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 100px 60px 60px;
    position: relative;
    overflow: hidden;
  }

  .hero-left { position: relative; z-index: 2; }

  .hero-tag {
    font-size: 0.68rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp 0.8s 0.3s forwards;
  }

  .hero-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.5rem, 7vw, 7rem);
    font-weight: 300;
    line-height: 0.9;
    color: var(--star);
    opacity: 0;
    animation: fadeUp 0.9s 0.5s forwards;
  }

  .hero-name em { font-style: italic; color: var(--accent); }

  .hero-title {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--rose);
    margin-top: 24px;
    opacity: 0;
    animation: fadeUp 0.9s 0.7s forwards;
  }

  .hero-desc {
    max-width: 420px;
    margin-top: 28px;
    font-size: 0.88rem;
    line-height: 1.9;
    color: var(--soft);
    opacity: 0;
    animation: fadeUp 0.9s 0.9s forwards;
  }

  .hero-cta {
    margin-top: 40px;
    display: flex;
    gap: 20px;
    opacity: 0;
    animation: fadeUp 0.9s 1.1s forwards;
    flex-wrap: wrap;
  }

  .btn-primary {
    padding: 13px 32px;
    border: 1px solid var(--accent);
    color: var(--accent);
    text-decoration: none;
    font-size: 0.68rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    transition: all 0.3s;
  }

  .btn-primary:hover { background: var(--accent); color: var(--space); }

  .btn-ghost {
    padding: 13px 32px;
    color: var(--soft);
    text-decoration: none;
    font-size: 0.68rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    transition: color 0.3s;
  }

  .btn-ghost:hover { color: var(--star); }

  /* HERO PHOTO */
  .hero-right {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
  }

  .hero-photo-wrap {
    position: relative;
    width: 420px;
    height: 560px;
    opacity: 0;
    animation: fadeIn 1.2s 0.8s forwards;
  }

  .hero-photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .hero-photo-wrap::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 200px;
    background: linear-gradient(to bottom, transparent, var(--space));
    pointer-events: none;
  }

  .orbit-ring-deco {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(201,169,110,0.15);
    pointer-events: none;
  }

  .orbit-ring-deco:nth-child(1) { width: 500px; height: 500px; top: 50%; left: 50%; transform: translate(-50%,-50%); animation: spin 30s linear infinite; }
  .orbit-ring-deco:nth-child(2) { width: 620px; height: 620px; top: 50%; left: 50%; transform: translate(-50%,-50%); border-color: rgba(212,160,176,0.08); animation: spin 50s linear infinite reverse; }

  .orbit-dot-deco {
    position: absolute;
    width: 7px; height: 7px;
    background: var(--gold);
    border-radius: 50%;
    box-shadow: 0 0 14px var(--gold);
    top: calc(50% - 250px);
    left: 50%;
    transform: translateX(-50%);
    animation: spin 30s linear infinite;
    transform-origin: 0 250px;
  }

  /* ABOUT */
  #about {
    padding: 100px 60px;
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .section-label {
    font-size: 0.65rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    color: var(--star);
    line-height: 1.15;
    margin-bottom: 24px;
  }

  .section-title em { font-style: italic; color: var(--accent); }

  .about-text {
    font-size: 0.88rem;
    line-height: 2;
    color: var(--soft);
    margin-bottom: 16px;
  }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 36px;
  }

  .stat {
    border-left: 1px solid rgba(201,169,110,0.3);
    padding-left: 18px;
  }

  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    color: var(--gold);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--soft);
    margin-top: 5px;
  }

  .about-dream {
    background: linear-gradient(135deg, rgba(13,21,53,0.8), rgba(4,6,15,0.4));
    border: 1px solid rgba(201,169,110,0.15);
    padding: 36px;
    position: relative;
  }

  .about-dream::before {
    content: '✦';
    position: absolute;
    top: 18px; right: 22px;
    color: var(--accent);
    opacity: 0.5;
  }

  .dream-quote {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    font-style: italic;
    color: var(--star);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .dream-sub {
    font-size: 0.78rem;
    color: var(--soft);
    line-height: 1.8;
  }

  /* EXPERIENCE */
  #experience {
    padding: 100px 60px;
    max-width: 900px;
    margin: 0 auto;
  }

  #experience .section-label,
  #experience .section-title { text-align: center; }
  #experience .section-title { margin-bottom: 60px; }

  .timeline { position: relative; padding-left: 36px; }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, transparent, var(--accent), rgba(201,169,110,0.2), transparent);
  }

  .timeline-item {
    position: relative;
    margin-bottom: 52px;
    opacity: 0;
    transform: translateX(-20px);
    transition: all 0.6s ease;
  }

  .timeline-item.visible { opacity: 1; transform: translateX(0); }

  .timeline-dot {
    position: absolute;
    left: -40px; top: 6px;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent);
  }

  .timeline-date {
    font-size: 0.63rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 6px;
  }

  .timeline-company {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    color: var(--star);
    margin-bottom: 4px;
  }

  .timeline-role {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: 14px;
  }

  .timeline-bullets { list-style: none; display: flex; flex-direction: column; gap: 10px; }

  .timeline-bullets li {
    font-size: 0.85rem;
    line-height: 1.8;
    color: var(--soft);
    padding-left: 16px;
    position: relative;
  }

  .timeline-bullets li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.5rem;
    top: 6px;
  }

  /* HIGHLIGHTS */
  #highlights {
    padding: 100px 60px;
    background: linear-gradient(to bottom, transparent, rgba(13,21,53,0.3), transparent);
  }

  #highlights .section-label,
  #highlights .section-title { text-align: center; }
  #highlights .section-title { margin-bottom: 52px; }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .highlight-card {
    border: 1px solid rgba(201,169,110,0.15);
    padding: 32px 24px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
    background: rgba(8,13,31,0.6);
  }

  .highlight-card:hover { border-color: rgba(201,169,110,0.4); transform: translateY(-4px); }

  .highlight-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--accent), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .highlight-card:hover::before { opacity: 1; }

  .highlight-icon { font-size: 1.3rem; margin-bottom: 16px; }

  .highlight-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.6rem;
    font-weight: 300;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 6px;
  }

  .highlight-title {
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: 10px;
  }

  .highlight-desc { font-size: 0.8rem; line-height: 1.8; color: var(--soft); }

  /* SKILLS */
  #skills { padding: 100px 60px; max-width: 1000px; margin: 0 auto; }

  #skills .section-label,
  #skills .section-title { text-align: center; }
  #skills .section-title { margin-bottom: 52px; }

  .skills-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 36px; }

  .skill-group-title {
    font-size: 0.66rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(201,169,110,0.2);
  }

  .skill-tags { display: flex; flex-wrap: wrap; gap: 8px; }

  .skill-tag {
    padding: 6px 14px;
    border: 1px solid rgba(201,169,110,0.2);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--soft);
    transition: all 0.3s;
  }

  .skill-tag:hover { border-color: var(--accent); color: var(--accent); }

  /* PORTFOLIO */
  #portfolio {
    padding: 100px 60px;
    background: linear-gradient(to bottom, transparent, rgba(13,21,53,0.2), transparent);
  }

  #portfolio .section-label,
  #portfolio .section-title { text-align: center; }
  #portfolio .section-title { margin-bottom: 52px; }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 1100px;
    margin: 0 auto;
    align-items: start;
  }

  .portfolio-card {
    border: 1px solid rgba(201,169,110,0.15);
    position: relative;
    overflow: hidden;
    background: var(--nebula);
    aspect-ratio: 4/3;
    transition: border-color 0.3s;
  }

  .portfolio-card:hover { border-color: rgba(201,169,110,0.4); }

  .portfolio-card img,
  .portfolio-card video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .portfolio-inner {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0d1535, #04060f);
    padding: 28px;
    text-align: center;
  }

  .portfolio-icon { font-size: 1.8rem; margin-bottom: 14px; }

  .portfolio-inner-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    color: var(--star);
    margin-bottom: 8px;
  }

  .portfolio-inner-sub {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .portfolio-inner-desc {
    font-size: 0.72rem;
    color: var(--soft);
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .portfolio-btn {
    padding: 7px 18px;
    border: 1px solid rgba(201,169,110,0.4);
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .portfolio-overlay {
    position: absolute;
    inset: 0;
    background: rgba(4,6,15,0.88);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s;
    padding: 24px;
    text-align: center;
  }

  .portfolio-card:hover .portfolio-overlay { opacity: 1; }

  .portfolio-overlay-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    color: var(--star);
    margin-bottom: 8px;
  }

  .portfolio-overlay-desc {
    font-size: 0.72rem;
    color: var(--soft);
    line-height: 1.7;
  }

  .video-tall {
    grid-row: span 2;
    aspect-ratio: 9/16;
  }

  /* CONTACT */
  #contact {
    padding: 120px 60px;
    text-align: center;
    max-width: 680px;
    margin: 0 auto;
  }

  .contact-intro {
    font-size: 0.88rem;
    line-height: 2;
    color: var(--soft);
    margin-bottom: 44px;
  }

  .contact-links {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
    margin-bottom: 52px;
  }

  .contact-link { display: flex; flex-direction: column; align-items: center; gap: 6px; text-decoration: none; color: var(--soft); transition: color 0.3s; }
  .contact-link:hover { color: var(--gold); }
  .contact-link-label { font-size: 0.6rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--accent); }
  .contact-link-value { font-size: 0.85rem; }

  .availability {
    display: inline-block;
    padding: 10px 26px;
    border: 1px solid rgba(100,200,100,0.3);
    color: rgba(150,220,150,0.8);
    font-size: 0.66rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }

  .availability::before { content: '● '; color: rgba(100,220,100,0.8); animation: blink 2s infinite; }

  footer {
    border-top: 1px solid rgba(201,169,110,0.1);
    padding: 28px 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .footer-name { font-family: 'Cormorant Garamond', serif; font-size: 0.9rem; color: var(--soft); letter-spacing: 0.1em; }
  .footer-dream { font-size: 0.63rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(201,169,110,0.4); font-style: italic; }

  /* ANIMATIONS */
  @keyframes fadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes spin { from { transform: translate(-50%,-50%) rotate(0deg); } to { transform: translate(-50%,-50%) rotate(360deg); } }
  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

  /* MOBILE */
  @media (max-width: 768px) {
    nav { padding: 16px 20px; }
    .nav-links { display: none; }

    #hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding: 100px 24px 40px;
    }

    .hero-right { display: none; }

